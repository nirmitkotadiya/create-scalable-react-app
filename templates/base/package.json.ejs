    "zustand": "^4.5.1"<% } %><% if (tailwind) { %>,
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "lucide-react": "^0.473.0"<% } %>
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.1"<% if (language === 'ts') { %>,
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1"<% } %><% if (tailwind) { %>,
    "tailwindcss": "^3.4.17",
    "postcss": "^8.5.1",
    "autoprefixer": "^10.4.20"<% } %><% if (testing) { %>,
