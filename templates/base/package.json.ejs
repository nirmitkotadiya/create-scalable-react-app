{
  "name": "<%= projectName %>",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "<%- language === 'ts' ? 'tsc -b && ' : '' %>vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"<% if (router) { %>,
    "react-router-dom": "^7.1.3"<% } %><% if (state === 'redux') { %>,
    "@reduxjs/toolkit": "^2.0.1",
