<% if (router) { %>
import { BrowserRouter, Routes, Route } from 'react-router-dom';
<% } %><% if (state === 'zustand') { %>
import { useStore } from './store';
<% } %><% if (structure === 'feature') { %>
import { Counter } from './features/counter';
import { AuthProfile } from './features/auth';
<% } %>

function App() {
  <% if (state === 'zustand') { %>const count = useStore((state) => state.count);
  const inc = useStore((state) => state.inc);<% } %>
  
  <% if (tailwind) { %>
  return (
    <% if (router) { %><BrowserRouter>
      <Routes>
        <Route path="/" element={<% } %>
          <div className="max-w-3xl mx-auto p-8 font-sans">
            <h1 className="text-3xl font-extrabold text-slate-800 mb-2">Welcome to <%= projectName %></h1>
            <p className="text-lg text-slate-500 mb-8">
              Dynamic application environment scaffolded successfully!
            </p>
            
            <% if (structure === 'feature') { %>
            <div className="flex flex-col gap-4">
              <Counter />
              <AuthProfile />
            </div>
            <% } else { %>
            <div className="p-8 border-2 border-dashed border-slate-300 rounded-lg text-center">
              <h2 className="text-xl font-semibold text-slate-700">Flat Structure Layout</h2>
              <p className="text-slate-500 mt-2">Add your code directly to the components folder.</p>
            </div>
            <% } %>

            <% if (state === 'zustand') { %>
            <div className="mt-8 p-6 bg-amber-50 rounded-lg border border-amber-200">
              <p className="text-amber-900 font-medium mb-4">Zustand Root Count: {count}</p>
              <button 
                onClick={inc} 
                className="px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white rounded transition-colors cursor-pointer"
              >
                Increment Zustand Global
              </button>
            </div>
            <% } %>
          </div>
        <% if (router) { %>} />
      </Routes>
    </BrowserRouter><% } %>
  );
  <% } else { %>
  return (
    <% if (router) { %><BrowserRouter>
      <Routes>
        <Route path="/" element={<% } %>
          <div style={{ maxWidth: '800px', margin: '0 auto', padding: '2rem', fontFamily: 'system-ui, sans-serif' }}>
            <h1 style={{ color: '#1e293b' }}>Welcome to <%= projectName %></h1>
            <p style={{ color: '#64748b', fontSize: '1.1rem', marginBottom: '2rem' }}>
              Dynamic application environment scaffolded successfully!
            </p>
            
            <% if (structure === 'feature') { %>
            <div style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>
              <Counter />
              <AuthProfile />
            </div>
            <% } else { %>
            <div style={{ padding: '2rem', border: '2px dashed #cbd5e1', borderRadius: '0.5rem', textAlign: 'center' }}>
              <h2 style={{ color: '#475569' }}>Flat Structure Layout</h2>
              <p>Add your code directly to the components folder.</p>
            </div>
            <% } %>

            <% if (state === 'zustand') { %>
            <div style={{ marginTop: '2rem', padding: '1rem', background: '#fef3c7', borderRadius: '0.5rem' }}>
              <p>Zustand Root Count: {count}</p>
              <button onClick={inc} style={{ padding: '0.5rem 1rem' }}>Increment Zustand Global</button>
            </div>
            <% } %>
          </div>
        <% if (router) { %>} />
      </Routes>
    </BrowserRouter><% } %>
  );
  <% } %>
}

export default App;
