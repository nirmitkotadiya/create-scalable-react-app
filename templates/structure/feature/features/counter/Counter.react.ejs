import { useState } from 'react';

export const Counter = () => {
  const [count, setCount] = useState(0);
  
  <% if (tailwind) { %>
  return (
    <div className="p-6 border border-slate-200 rounded-lg mb-4 bg-slate-50">
      <h2 className="text-xl font-bold text-slate-900 mt-0 mb-2">Counter Module</h2>
      <p className="text-slate-600 mb-4">Current value: <strong className="font-semibold text-slate-900">{count}</strong></p>
      <button 
        className="px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white font-medium rounded transition-colors cursor-pointer"
        onClick={() => setCount(c => c + 1)}
      >
        Increment
      </button>
    </div>
  );
  <% } else { %>
  return (
    <div style={{ padding: '1.5rem', border: '1px solid #e2e8f0', borderRadius: '0.5rem', marginBottom: '1rem', backgroundColor: '#f8fafc' }}>
      <h2 style={{ marginTop: 0, color: '#0f172a' }}>Counter Module</h2>
      <p style={{ color: '#475569' }}>Current value: <strong>{count}</strong></p>
      <button 
        style={{ padding: '0.5rem 1rem', backgroundColor: '#3b82f6', color: 'white', border: 'none', borderRadius: '0.25rem', cursor: 'pointer' }} 
        onClick={() => setCount(c => c + 1)}
      >
        Increment
      </button>
    </div>
  );
  <% } %>
};
